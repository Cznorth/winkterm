# ============================================================
# WinkTerm 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ------ MiniMax ------
# 必填：MiniMax API Key
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax API 地址（默认即可）
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2

# 可选：使用的模型（默认 MiniMax-M2.7）
MODEL_NAME=MiniMax-M2.7

# ------ 外部服务 ------
# Prometheus 地址（暂为 mock）
PROMETHEUS_URL=http://localhost:9090

# Loki 地址（暂为 mock）
LOKI_URL=http://localhost:3100

# ------ 后端服务器 ------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ------ 前端 ------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/terminal
